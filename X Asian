    # --- NEW & UPDATED VISUALIZATION METHODS ---

    def plot_normalization_comparison(self, df_vega, bins_years=(1/6, 3/4, 2.0)):
        """Plots Raw vs Normalized vs Smoothed (Binned) Vega on the same chart."""
        df = df_vega.copy()
        df["VegaTenor"] = pd.to_numeric(df["VegaTenor"], errors="coerce")
        df["Value"] = pd.to_numeric(df["Value"], errors="coerce").fillna(0.0)
        
        # 1. Raw & Unbinned Normalized
        T_eff = np.maximum(df["VegaTenor"], 1/52)
        df["Normalized_Value"] = df["Value"] / np.sqrt(T_eff)
        agg_raw_norm = df.groupby("VegaTenor")[["Value", "Normalized_Value"]].sum()
        
        # 2. Smoothed Binned
        df_binned = self.normalize_and_bin_vega(df, "VegaTenor", "Value", bins_years)
        agg_binned = df_binned.groupby("BinnedTenor")["AllocatedValue"].sum()
        
        plt.figure(figsize=(12, 6))
        # Original Tenor plots
        plt.plot(agg_raw_norm.index, agg_raw_norm["Value"], marker='o', color='gray', linestyle=':', label="Raw Vega (Actual Expiries)")
        plt.plot(agg_raw_norm.index, agg_raw_norm["Normalized_Value"], marker='x', color='teal', alpha=0.5, label="Normalized (Actual Expiries)")
        
        # Binned Node plot
        plt.plot(agg_binned.index, agg_binned.values, marker='D', markersize=8, color='crimson', linewidth=2, label="Smoothed & Binned Vega (Nodes)")
        
        # Mark the bin nodes vertically
        for b in bins_years:
            plt.axvline(b, color='black', linestyle='--', alpha=0.3)
            
        plt.title("Understanding Smoothing: Raw vs Normalized vs Binned Allocation")
        plt.xlabel("Maturity (Years)")
        plt.ylabel("Cumulative Vega Risk")
        plt.legend()
        plt.grid(alpha=0.3)
        plt.show()

    def plot_product_scenario(self, df_product, ticker=None):
