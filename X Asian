import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import PureWindowsPath
import pymfl
from pymfl.translator import translate


class VegaRiskManager:
    def __init__(self, base_uri=r"\\ibgvsnyeq\usequityderivs"):
        self.base_uri = base_uri
        self.valuation_date = None
        
    def _to_df(self, rows, dtypes=None):
        df = pd.DataFrame(rows[1:], columns=rows[0])
        return df.astype(dtypes) if dtypes else df

    def fetch_data(self, target_date, product_file_pattern="ESPU_Detailed_ProductUnderlier", vega_file_pattern="ESPU-MC_EquityVega_Risk"):
        """Fetches the raw AVRO files into pandas DataFrames without premature filtering."""
        self.valuation_date = pd.to_datetime(target_date, format="%Y%m%d")
        df_product, df_vega = None, None
        
        try:
            base = PureWindowsPath(self.base_uri)
            product_path = base / "Slides" / target_date / f"{target_date}_{product_file_pattern}.avro"
            vega_path    = base / "PAA" / "EquityVol.Vega" / target_date / f"{vega_file_pattern}.avro"
            
            print(f"Fetching {product_path}...")
            raw_prod = pymfl.xl().loadTable(fileName=str(product_path))
            df_product = self._to_df(translate(pymfl.xl().unpack(raw_prod)))
            
            print(f"Fetching {vega_path}...")
            raw_vega = pymfl.xl().loadTable(fileName=str(vega_path))
            df_vega = self._to_df(translate(pymfl.xl().unpack(raw_vega)))
            
        except Exception as e:
            print(f"Error fetching from AVRO directly: {e}")
            return None, None
            
        return df_product, df_vega
    

    def process_data(self, df_product, df_vega, target_date, ticker=None, books=["SSTK", "WOSR", "ASIA"], transits=['H2022']):
        """Uses YOUR EXACT LOGIC to clean, filter, and derive Expiry/Tenor."""
        valuation_date = pd.to_datetime(target_date, format="%Y%m%d").normalize()

        # --- 1. PRODUCT TABLE PROCESSING ---
        df_product["ScenarioName"] = pd.to_numeric(df_product["ScenarioName"].astype(str).str.rstrip('%'), errors='coerce') / 100

        df_product_processed = df_product[
            (df_product["Type"] == "Vega") &
            (df_product["Book"].isin(books)) &
            (df_product["Transit"].isin(transits)) &
            (df_product["RiskInstrument"].astype(str).str.contains(ticker, na=False))
        ].copy()

        df_product_processed["ScenarioValue"] = pd.to_numeric(df_product_processed["ScenarioValue"], errors="coerce").fillna(0.0)

        scenario_blank = df_product_processed["ScenarioName"].isna() | (df_product_processed["ScenarioName"].astype(str).str.strip() == "")
        vegaexpiry_blank = df_product_processed["VegaExpiry"].isna() | (df_product_processed["VegaExpiry"].astype(str).str.strip() == "")

        vegaexpiry_dt = pd.to_datetime(df_product_processed["VegaExpiry"].astype(str).str.replace(r"\.0$", "", regex=True), errors="coerce")

        instr_last8 = df_product_processed["Instrument1"].astype(str).str.extract(r"(\d{8})$")[0]
        instr_last8_dt = pd.to_datetime(instr_last8, format="%Y%m%d", errors="coerce")

        instr_last5 = df_product_processed["Instrument1"].astype(str).str.extract(r"(\d{5})$")[0]
        instr_last5_num = pd.to_numeric(instr_last5, errors="coerce")

        expiry = pd.Series(pd.NA, index=df_product_processed.index, dtype="object")
        expiry_dt = pd.Series(pd.NaT, index=df_product_processed.index)

        m1 = ~scenario_blank & ~vegaexpiry_blank
        expiry.loc[m1] = vegaexpiry_dt.loc[m1]
        expiry_dt.loc[m1] = vegaexpiry_dt.loc[m1]

        m2 = ~scenario_blank & vegaexpiry_blank & (df_product_processed["Type"].astype(str) == "Div01")
        expiry.loc[m2] = instr_last5_num.loc[m2]

        m3 = ~scenario_blank & vegaexpiry_blank & (df_product_processed["RiskType"].astype(str) == "FwdVol.Vega")
        expiry.loc[m3] = instr_last8_dt.loc[m3]
        expiry_dt.loc[m3] = instr_last8_dt.loc[m3]

        df_product_processed["Expiry"] = expiry
        df_product_processed["VolTenor"] = (expiry_dt - valuation_date).dt.days / 365.0

        # --- 2. VEGA RISK TABLE PROCESSING ---
        df_vega_processed = df_vega[
            (df_vega["Book"].isin(books)) &
            (df_product["Transit"].isin(transits)) &
            (df_vega["RiskInstrument"].astype(str) == ticker)
        ].copy()

        df_vega_processed["Value"] = pd.to_numeric(df_vega_processed["Value"], errors="coerce").fillna(0.0)
        df_vega_processed["VegaMoneyness"] = df_vega_processed["VegaMoneyness"].astype(float)

        group_keys = [
            "Instrument1", "TradeGroup", "Transit", "Book", "HedgeableUnit",
            "SecurityType", "ProductType", "RiskInstrument", "VegaExpiry",
            "VegaMoneyness", "VegaTenor"
        ]
        
        # Guard against missing columns in raw data before grouping
        valid_keys = [k for k in group_keys if k in df_vega_processed.columns]
        
        df_vega_processed_agg = (
            df_vega_processed
            .groupby(valid_keys, dropna=False, as_index=False)["Value"]
            .sum()
        )

        return df_product_processed, df_vega_processed_agg

    # --- DOWNSTREAM TASKS (Normalization, Binning, Plotting) ---

    def normalize_and_bin_vega(self, df, tenor_col, value_col, bins_years=(1/6, 3/4, 2.0), t_ref=1.0, t_min=1/52, alpha=1.0):
        """Your partial smoothing logic: normalizes and applies alpha-parameterized binning."""
        df_norm = df.copy()
        df_norm[tenor_col] = pd.to_numeric(df_norm[tenor_col], errors='coerce')
        df_norm = df_norm.dropna(subset=[tenor_col]).copy()
        
        floor_t = np.maximum(df_norm[tenor_col], t_min)
        weights = np.sqrt(t_ref / floor_t)
        df_norm['NormalizedValue'] = df_norm[value_col] * weights
        
        bins = sorted(list(bins_years))
        allocated_records = []
        
        for _, row in df_norm.iterrows():
            t = row[tenor_col]
            val = row['NormalizedValue']
            
            if t <= bins[0]:
                row_copy = row.copy()
                row_copy['BinnedTenor'] = bins[0]
                row_copy['AllocatedValue'] = val
                allocated_records.append(row_copy)
            elif t >= bins[-1]:
                row_copy = row.copy()
                row_copy['BinnedTenor'] = bins[-1]
                row_copy['AllocatedValue'] = val
                allocated_records.append(row_copy)
            else:
                for i in range(len(bins)-1):
                    if bins[i] <= t < bins[i+1]:
                        b_lower, b_upper = bins[i], bins[i+1]
                        L = b_upper - b_lower
                        M = (b_lower + b_upper) / 2.0
                        W = alpha * L
                        
                        if alpha == 0.0:
                            w_upper = 0.0 if t < M else 1.0
                        else:
                            T_start, T_end = M - W / 2.0, M + W / 2.0
                            if t <= T_start: w_upper = 0.0
                            elif t >= T_end: w_upper = 1.0
                            else: w_upper = (t - T_start) / (T_end - T_start)
                                
                        w_lower = 1.0 - w_upper
                        
                        if w_lower > 0:
                            row_lower = row.copy()
                            row_lower['BinnedTenor'] = b_lower
                            row_lower['AllocatedValue'] = val * w_lower
                            allocated_records.append(row_lower)
                        if w_upper > 0:
                            row_upper = row.copy()
                            row_upper['BinnedTenor'] = b_upper
                            row_upper['AllocatedValue'] = val * w_upper
                            allocated_records.append(row_upper)
                        break
                        
        return pd.DataFrame(allocated_records)

    def plot_normalization_comparison(self, df_vega_agg, bins_years=(1/6, 3/4, 2.0), t_ref=1.0, t_min=1/52, alpha=1.0):
        """Plots Raw Vega (Bars) vs Normalized (Line) vs Smoothed (Line) on exactly your aggregated data."""
        df = df_vega_agg.copy()
        df["VegaTenor"] = pd.to_numeric(df["VegaTenor"], errors="coerce")
        df["Value"] = pd.to_numeric(df["Value"], errors="coerce").fillna(0.0)
        
        # 1. Raw & Unbinned Normalized Baseline
        T_eff = np.maximum(df["VegaTenor"], t_min)
        df["Normalized_Value"] = df["Value"] / np.sqrt(T_eff)
        agg_raw_norm = df.groupby("VegaTenor")[["Value", "Normalized_Value"]].sum()
        
        # 2. Alpha-Smoothed Binned Allocation
        df_binned = self.normalize_and_bin_vega(df, "VegaTenor", "Value", bins_years, t_ref, t_min, alpha)
        agg_binned = df_binned.groupby("BinnedTenor")["AllocatedValue"].sum()
        
        fig, ax = plt.subplots(figsize=(12, 6))
        
        # Histogram (Bars) for Raw Vega
        ax.bar(agg_raw_norm.index, agg_raw_norm["Value"], width=0.02, color='slategray', alpha=0.6, label="Raw Vega (Unnormalized)")
        
        # Line Curve for Unbinned Normalized Vega
        ax.plot(agg_raw_norm.index, agg_raw_norm["Normalized_Value"], marker='x', linestyle=':', color='teal', label="Normalized Vega (Actual Expiries)")
        
        # Line Curve for Smoothed Binned Vega
        ax.plot(agg_binned.index, agg_binned.values, marker='D', markersize=8, color='crimson', linewidth=2.5, label=f"Smoothed Binned Vega (Alpha={alpha})")
        
        for b in bins_years:
            ax.axvline(b, color='black', linestyle='--', alpha=0.3)
            
        ax.set_title(f"Vega Risk Allocation: Raw Exposures vs. Normalized & Smoothed (Alpha={alpha})")
        ax.set_xlabel("Maturity (Years)")
        ax.set_ylabel("Cumulative Vega Risk")
        ax.legend()
        ax.grid(axis='y', alpha=0.3)
        plt.show()
        
    def plot_product_scenario(self, df_product, ticker=None):
        """Visualizes Vega shock scenarios from the Product table."""
        df = df_product[df_product["RiskInstrument"] == ticker].copy() if ticker else df_product.copy()
        
        # Group by the cleaned ScenarioName
        agg_scenario = df.groupby("ScenarioName")["ScenarioValue"].sum().sort_index()
        
        plt.figure(figsize=(10, 5))
        plt.plot(agg_scenario.index, agg_scenario.values, marker='o', color='darkorange', linewidth=2)
        plt.axhline(0, color='black', linewidth=1)
        plt.axvline(0, color='black', linewidth=1, linestyle='--')
        
        title_str = f"{ticker} Vega by Market Scenario" if ticker else "Total Portfolio Vega by Market Scenario"
        plt.title(title_str)
        plt.xlabel("Market Shock Scenario (e.g., -0.50 = -50% drop)")
        plt.ylabel("Aggregated Vega Exposure")
        plt.grid(alpha=0.3)
        plt.show()

    def plot_portfolio_summary(self, df_vega_agg, top_n=10):
        """Visualizes the top absolute exposures across the portfolio."""
        df = df_vega_agg.copy()
        
        # Calculate absolute sum per instrument to find biggest movers
        agg_port = df.groupby("RiskInstrument")["Value"].sum().abs().sort_values(ascending=False).head(top_n)
        
        if agg_port.empty:
            print("No data available to plot portfolio summary.")
            return

        plt.figure(figsize=(12, 6))
        sns.barplot(x=agg_port.values, y=agg_port.index, palette="viridis")
        plt.title(f"Top {top_n} Portfolio Vega Exposures (Absolute Magnitude)")
        plt.xlabel("Total Absolute Vega")
        plt.ylabel("Risk Instrument")
        plt.grid(axis='x', alpha=0.3)
        plt.show()

    def plot_unbinned_normalized_barplot(self, df_vega_agg):
        """Bar plot of Unbinned Normalized Total Vega by Tenor."""
        df = df_vega_agg.copy()
        df["VegaTenor"] = pd.to_numeric(df["VegaTenor"], errors="coerce")
        df["Value"] = pd.to_numeric(df["Value"], errors="coerce").fillna(0.0)
        
        # Apply normalization
        T_eff = np.maximum(df["VegaTenor"], 1/52)
        df["NormalizedValue"] = df["Value"] / np.sqrt(T_eff)
        
        # Aggregate by Tenor
        df_unbinned_agg = df.groupby("VegaTenor")["NormalizedValue"].sum().reset_index()
        
        plt.figure(figsize=(10, 5))
        sns.barplot(data=df_unbinned_agg, x="VegaTenor", y="NormalizedValue", color="royalblue")
        plt.title("Unbinned Normalized Total Vega by Tenor")
        plt.xlabel("Time to Expiry (Years)")
        plt.ylabel("Normalized Vega Exposure")
        plt.xticks(rotation=45)
        plt.grid(axis='y', alpha=0.3)
        plt.show()

    def plot_binned_heatmap(self, df_vega_agg, bins_years=(1/6, 3/4, 2.0), alpha=0.5, ticker="TSLA.O"):
        """Generates a heatmap for the binned exposure required by the desk."""
        # Run the binning logic
        df_binned = self.normalize_and_bin_vega(df_vega_agg, "VegaTenor", "Value", bins_years, alpha=alpha)
        
        # Pivot by Moneyness and Binned Tenor
        pivot_binned = pd.pivot_table(
            df_binned,
            index="VegaMoneyness",
            columns="BinnedTenor",
            values="AllocatedValue",
            aggfunc="sum",
            fill_value=0.0
        )
        
        plt.figure(figsize=(10, 8))
        sns.heatmap(pivot_binned, cmap="RdBu", center=0, annot=True, fmt=".0f", linewidths=.5)
        plt.title(f"{ticker} - Binned Normalized Vega Exposure by Moneyness (Alpha={alpha})")
        plt.ylabel("Strike Moneyness")
        plt.xlabel("Continuous Term Buckets (Years)")
        plt.show()




    def __init__(self, base_uri=r"\\ibgvsnyeq\usequityderivs", local_path=None, 
                 bins_years=(1/6, 3/4, 2.0), t_ref=1.0, t_min=1/52, alpha=1.0):
        self.base_uri = base_uri
        self.local_path = local_path
        self.valuation_date = None
        
        self.bins_years = sorted(list(bins_years))
        self.t_ref = t_ref
        self.t_min = t_min
        self.alpha = alpha


    def fetch_data(self, target_date, product_file_pattern="ESPU_Detailed_ProductUnderlier", vega_file_pattern="ESPU-MC_EquityVega_Risk"):
        """Fetches AVRO files, prioritizing local cache if specified."""
        self.valuation_date = pd.to_datetime(target_date, format="%Y%m%d")
        
        # I am using .pkl here because pandas to_csv loses exact datatypes (like datetimes), which can break downstream logic
        if self.local_path:
            local_dir = PureWindowsPath(self.local_path)
            prod_local = local_dir / f"{target_date}_{product_file_pattern}.pkl"
            vega_local = local_dir / f"{target_date}_{vega_file_pattern}.pkl"
            
            if prod_local.exists() and vega_local.exists():
                print(f"Loading from local cache: {self.local_path}")
                return pd.read_pickle(prod_local), pd.read_pickle(vega_local)
                
        base = PureWindowsPath(self.base_uri)
        product_path = base / "Slides" / target_date / f"{target_date}_{product_file_pattern}.avro"
        vega_path    = base / "PAA" / "EquityVol.Vega" / target_date / f"{vega_file_pattern}.avro"
        
        print(f"Fetching {product_path}...")
        raw_prod = pymfl.xl().loadTable(fileName=str(product_path))
        df_product = self._to_df(translate(pymfl.xl().unpack(raw_prod)))
        
        print(f"Fetching {vega_path}...")
        raw_vega = pymfl.xl().loadTable(fileName=str(vega_path))
        df_vega = self._to_df(translate(pymfl.xl().unpack(raw_vega)))
        
        if self.local_path:
            df_product.to_pickle(prod_local)
            df_vega.to_pickle(vega_local)
            
        return df_product, df_vega


    def process_data(self, df_product, df_vega, target_date, ticker=None, books=["SSTK", "WOSR", "ASIA"], transits=['H2022']):
        """Cleans, filters, and derives Expiry/Tenor for single names or the entire portfolio."""
        valuation_date = pd.to_datetime(target_date, format="%Y%m%d").normalize()

        # --- 1. PRODUCT TABLE PROCESSING ---
        df_product["ScenarioName"] = pd.to_numeric(df_product["ScenarioName"].astype(str).str.rstrip('%'), errors='coerce') / 100

        prod_mask = (df_product["Type"] == "Vega") & (df_product["Book"].isin(books)) & (df_product["Transit"].isin(transits))
        if ticker:
            prod_mask &= df_product["RiskInstrument"].astype(str).str.contains(ticker, na=False)

        df_product_processed = df_product[prod_mask].copy()

        df_product_processed["ScenarioValue"] = pd.to_numeric(df_product_processed["ScenarioValue"], errors="coerce").fillna(0.0)

        scenario_blank = df_product_processed["ScenarioName"].isna() | (df_product_processed["ScenarioName"].astype(str).str.strip() == "")
        vegaexpiry_blank = df_product_processed["VegaExpiry"].isna() | (df_product_processed["VegaExpiry"].astype(str).str.strip() == "")

        vegaexpiry_dt = pd.to_datetime(df_product_processed["VegaExpiry"].astype(str).str.replace(r"\.0$", "", regex=True), errors="coerce")

        instr_last8 = df_product_processed["Instrument1"].astype(str).str.extract(r"(\d{8})$")[0]
        instr_last8_dt = pd.to_datetime(instr_last8, format="%Y%m%d", errors="coerce")

        instr_last5 = df_product_processed["Instrument1"].astype(str).str.extract(r"(\d{5})$")[0]
        instr_last5_num = pd.to_numeric(instr_last5, errors="coerce")

        expiry = pd.Series(pd.NA, index=df_product_processed.index, dtype="object")
        expiry_dt = pd.Series(pd.NaT, index=df_product_processed.index)

        m1 = ~scenario_blank & ~vegaexpiry_blank
        expiry.loc[m1] = vegaexpiry_dt.loc[m1]
        expiry_dt.loc[m1] = vegaexpiry_dt.loc[m1]

        m2 = ~scenario_blank & vegaexpiry_blank & (df_product_processed["Type"].astype(str) == "Div01")
        expiry.loc[m2] = instr_last5_num.loc[m2]

        m3 = ~scenario_blank & vegaexpiry_blank & (df_product_processed["RiskType"].astype(str) == "FwdVol.Vega")
        expiry.loc[m3] = instr_last8_dt.loc[m3]
        expiry_dt.loc[m3] = instr_last8_dt.loc[m3]

        df_product_processed["Expiry"] = expiry
        df_product_processed["VolTenor"] = (expiry_dt - valuation_date).dt.days / 365.0

        # --- 2. VEGA RISK TABLE PROCESSING ---
        
        # Changed df_product["Transit"] to df_vega["Transit"] as referencing df_product inside df_vega masking drops dimensions
        vega_mask = (df_vega["Book"].isin(books)) & (df_vega["Transit"].isin(transits))
        if ticker:
            vega_mask &= (df_vega["RiskInstrument"].astype(str) == ticker)

        df_vega_processed = df_vega[vega_mask].copy()

        df_vega_processed["Value"] = pd.to_numeric(df_vega_processed["Value"], errors="coerce").fillna(0.0)
        df_vega_processed["VegaMoneyness"] = df_vega_processed["VegaMoneyness"].astype(float)

        group_keys = [
            "Instrument1", "TradeGroup", "Transit", "Book", "HedgeableUnit",
            "SecurityType", "ProductType", "RiskInstrument", "VegaExpiry",
            "VegaMoneyness", "VegaTenor"
        ]
        
        valid_keys = [k for k in group_keys if k in df_vega_processed.columns]
        
        df_vega_processed_agg = (
            df_vega_processed
            .groupby(valid_keys, dropna=False, as_index=False)["Value"]
            .sum()
        )

        return df_product_processed, df_vega_processed_agg



    def plot_portfolio_summary(self, df_vega_agg, top_n=10):
        """Visualizes the top positive and negative vega exposures across the portfolio."""
        df = df_vega_agg.copy()
        agg_port = df.groupby("RiskInstrument")["Value"].sum()
        
        top_pos = agg_port[agg_port > 0].nlargest(top_n)
        top_neg = agg_port[agg_port < 0].nsmallest(top_n)
        
        combined = pd.concat([top_pos, top_neg]).sort_values()
        
        if combined.empty:
            print("No data available to plot portfolio summary.")
            return

        plt.figure(figsize=(12, 8))
        colors = ['crimson' if val < 0 else 'royalblue' for val in combined.values]
        sns.barplot(x=combined.values, y=combined.index, palette=colors)
        
        plt.axvline(0, color='black', linewidth=1)
        plt.title(f"Top {top_n} Positive and Negative Portfolio Vega Exposures")
        plt.xlabel("Net Vega Contribution")
        plt.ylabel("Risk Instrument")
        plt.grid(axis='x', alpha=0.3)
        plt.show()


