    def normalize_and_bin_vega(self, df, tenor_col, value_col, bins_years=(1/6, 3/4, 2.0), t_ref=1.0, t_min=1/52, alpha=1.0):
        """
        Normalizes vega and allocates risk to predefined bins using an alpha-parameterized blending window.
        alpha=0.0: Nearest-neighbor hard cutoff
        alpha=1.0: Full continuous linear interpolation
        """
        df_norm = df.copy()
        df_norm[tenor_col] = pd.to_numeric(df_norm[tenor_col], errors='coerce')
        df_norm = df_norm.dropna(subset=[tenor_col]).copy()
        
        # 1. Normalize Vega
        floor_t = np.maximum(df_norm[tenor_col], t_min)
        weights = np.sqrt(t_ref / floor_t)
        df_norm['NormalizedValue'] = df_norm[value_col] * weights
        
        # 2. Alpha-Parameterized Binning
        bins = sorted(list(bins_years))
        allocated_records = []
        
        for _, row in df_norm.iterrows():
            t = row[tenor_col]
            val = row['NormalizedValue']
            
            if t <= bins[0]:
                row_copy = row.copy()
                row_copy['BinnedTenor'] = bins[0]
                row_copy['AllocatedValue'] = val
                allocated_records.append(row_copy)
            elif t >= bins[-1]:
                row_copy = row.copy()
                row_copy['BinnedTenor'] = bins[-1]
                row_copy['AllocatedValue'] = val
                allocated_records.append(row_copy)
            else:
                for i in range(len(bins)-1):
                    if bins[i] <= t < bins[i+1]:
                        b_lower, b_upper = bins[i], bins[i+1]
                        
                        L = b_upper - b_lower
                        M = (b_lower + b_upper) / 2.0
                        W = alpha * L
                        
                        # Handle the strict alpha=0 case to prevent divide-by-zero
                        if alpha == 0.0:
                            w_upper = 0.0 if t < M else 1.0
                        else:
                            T_start = M - W / 2.0
                            T_end   = M + W / 2.0
                            
                            if t <= T_start:
                                w_upper = 0.0
                            elif t >= T_end:
                                w_upper = 1.0
                            else:
                                w_upper = (t - T_start) / (T_end - T_start)
                                
                        w_lower = 1.0 - w_upper
                        
                        if w_lower > 0:
                            row_lower = row.copy()
                            row_lower['BinnedTenor'] = b_lower
                            row_lower['AllocatedValue'] = val * w_lower
                            allocated_records.append(row_lower)
                            
                        if w_upper > 0:
                            row_upper = row.copy()
                            row_upper['BinnedTenor'] = b_upper
                            row_upper['AllocatedValue'] = val * w_upper
                            allocated_records.append(row_upper)
                        break
                        
        return pd.DataFrame(allocated_records)

    def plot_normalization_comparison(self, df_vega, bins_years=(1/6, 3/4, 2.0), alphas=[0.0, 0.5, 1.0]):
        """Visualizes how different alpha values impact the final risk allocation at the nodes."""
        df = df_vega.copy()
        df["VegaTenor"] = pd.to_numeric(df["VegaTenor"], errors="coerce")
        df["Value"] = pd.to_numeric(df["Value"], errors="coerce").fillna(0.0)
        
        # Unbinned Normalized Baseline
        T_eff = np.maximum(df["VegaTenor"], 1/52)
        df["Normalized_Value"] = df["Value"] / np.sqrt(T_eff)
        agg_raw_norm = df.groupby("VegaTenor")["Normalized_Value"].sum()
        
        plt.figure(figsize=(12, 6))
        plt.plot(agg_raw_norm.index, agg_raw_norm.values, marker='x', color='gray', alpha=0.5, label="Unbinned Normalized (Actual Expiries)")
        
        # Test different alphas
        colors = ['crimson', 'teal', 'darkorange']
        labels = ['Hard Cutoff (Alpha=0)', 'Partial Smoothing (Alpha=0.5)', 'Full Smoothing (Alpha=1.0)']
        
        for idx, a in enumerate(alphas):
            df_binned = self.normalize_and_bin_vega(df, "VegaTenor", "Value", bins_years, alpha=a)
            agg_binned = df_binned.groupby("BinnedTenor")["AllocatedValue"].sum()
            plt.plot(agg_binned.index, agg_binned.values, marker='D', markersize=8, linewidth=2, color=colors[idx], label=labels[idx])
            
        for b in bins_years:
            plt.axvline(b, color='black', linestyle='--', alpha=0.2)
            
        plt.title("Impact of Alpha Parameter on Binned Vega Allocation")
        plt.xlabel("Maturity Nodes (Years)")
        plt.ylabel("Cumulative Allocated Vega")
        plt.legend()
        plt.grid(alpha=0.3)
        plt.show()


