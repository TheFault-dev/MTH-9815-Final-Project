@dataclass(frozen=True)
class Curve:
    pricing_date: dt.date = dt.date.today()
    currency: str = "USD"

    @property
    def calendar_name(self) -> str:
        # Map currency to respective exchange/holiday calendars
        return {"USD": "NYSE", "EUR": "TARGET", "GBP": "LSE", "JPY": "TSE"}.get(self.currency.upper(), "NYSE")

    @property
    def forward_curve(self) -> str:
        # Map currency to respective OIS / Risk-Free Rates
        curve_map = {
            "USD": "USD_SOFR",
            "EUR": "EUR_ESTR",
            "GBP": "GBP_SONIA",
            "JPY": "JPY_TONA",
            "CHF": "CHF_SARON"
        }
        return curve_map.get(self.currency.upper(), f"{self.currency.upper()}_OIS")

    @property
    def discount_curve(self) -> str:
        # Usually matches the forward curve for single-currency options
        return self.forward_curve
        
