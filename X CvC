import pandas as pd
from scipy import optimize

class PairwiseBasket(Basket):
    def get_price_for_matrix(self, corr_matrix: list) -> float:
        asset_data = []
        for i, t in enumerate(self.tickers):
            asset_data.append({
                "Price": t.initial_fixing_price * t.spot_multiplier,
                "CurrencySymbol": t.curve.currency, "Symbol": t.index,
                "Volatility": t.vol_surface, "Dividend": t.dividend,
                "ForecastCurveSymbol": "Forecast", "Correlations": corr_matrix[i]
            })
            
        ctxt = {
            "ValueDate": self.curve.pricing_date,
            "AssetData": asset_data,
            "CurrencyData": [{"Name": self.curve.currency, "CurveData": [{"Name": "Forecast"}]}],
            "ModelParameters": self.model,
            "Product": {
                "AnalyticType": "MM3Beisser", "PayoffType": self.option_type.value,
                "CurrencySymbol": self.curve.currency, "FaceValue": 1,
                "Participation": 1, "PercentageStrike": self.strike,
                "GuaranteedPercentage": 0, "InceptionDate": self.curve.pricing_date,
                "MaturityDate": self.expiry, "Schedule": [self.expiry],
                "BasketItems": [{"UnderlyingSymbol": t.index, "Weight": t.weight, "InitialFixing": t.initial_fixing_price} for t in self.tickers]
            }
        }
        ctx_temp = _equity.AsianBasket_Contextualize_Temp(ctxt=ctxt, forecasts=[[self.curve.discount_curve_object]], discount=self.curve.discount_curve_object)
        return -_pymfl.MarketResult(_equity.AsianBasket_Valuation(ctx_temp)).Pv()

