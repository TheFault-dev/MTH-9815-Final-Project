import time
import win32com.client
from quote_parser import parse_broker_quote
from CvC_pricer import init_mfl, get_model_parameters, price_single_quote

MFL_DIRECTORY = r"C:\Temp\MFL\CmProd_16.6.6_16.6.6\Output" 
OUTLOOK_FOLDER = "BrokerQuotes"
DESK_EMAIL = "desk@yourcompany.com"
POLL_INTERVAL = 60

def process_inbox(outlook, model_params):
    namespace = outlook.GetNamespace("MAPI")
    inbox = namespace.GetDefaultFolder(6) 
    target_folder = inbox.Folders.Item(OUTLOOK_FOLDER)
    
    unread_messages = target_folder.Items.Restrict("[UnRead] = True")
    
    for msg in unread_messages:
        print(f"\nProcessing new quote from {msg.SenderName}: {msg.Subject}")
        
        quote_str = parse_broker_quote(msg.Body)
        implied_corr = price_single_quote(quote_str, model_params)
        
        reply = outlook.CreateItem(0)
        reply.To = DESK_EMAIL
        reply.Subject = f"Pricing Result: {msg.Subject}"
        reply.Body = (
            f"--- Automated Pricing Results ---\n\n"
            f"Parsed Quote: {quote_str}\n"
            f"Implied Bid Correlation: {implied_corr['bid']:.4%}\n"
            f"Implied Ask Correlation: {implied_corr['ask']:.4%}\n"
        )
        reply.Send()
        print(f"Successfully sent results to {DESK_EMAIL}.")
        
        msg.UnRead = False

if __name__ == "__main__":
    init_mfl(MFL_DIRECTORY)
    model = get_model_parameters()
    outlook_app = win32com.client.Dispatch("Outlook.Application")
    
    print(f"Listening for unread emails in Inbox\\{OUTLOOK_FOLDER}...")
    while True:
        process_inbox(outlook_app, model)
        time.sleep(POLL_INTERVAL)


