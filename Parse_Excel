import openpyxl
from openpyxl.formula import Tokenizer
from openpyxl.formula.translate import Translator
from openpyxl.utils.cell import get_column_letter, range_boundaries, coordinate_to_tuple
import re

class ExcelFormulaTracer:
    def __init__(self, filepath):
        print(f"Loading workbook: {filepath} (This might take a moment...)")
        self.wb = openpyxl.load_workbook(filepath, data_only=False)
        self.sheet_names = self.wb.sheetnames
        self.global_visited = {}

    def get_cell_name(self, ws, row, col):
        """Heuristically extracts a human-readable name from the cell to the left or above."""
        name_left, name_above = "", ""
        try:
            if col > 1:
                val = ws.cell(row=row, column=col-1).value
                if isinstance(val, str) and val.strip() and not val.startswith('='):
                    name_left = val.strip()
            if row > 1:
                val = ws.cell(row=row-1, column=col).value
                if isinstance(val, str) and val.strip() and not val.startswith('='):
                    name_above = val.strip()
        except Exception:
            pass
        
        if name_left and name_above: return f"{name_left} | {name_above}"
        return name_left or name_above or ""

    def get_formula_string(self, ws, cell_coord):
        """
        Safely extracts the formula string. This avoids the #VALUE! stoppage when parsing 
        Array Formulas or orphaned Shared Formulas that lack an explicit formula tag in the XML.
        """
        cell = ws[cell_coord]
        val = cell.value

        if isinstance(val, str) and val.startswith("="):
            return val

        if hasattr(val, 'text') and val.text:
            return "=" + val.text.lstrip("=")

        # 1. Check if the cell lives inside an Array Formula block
        coord_tuple = coordinate_to_tuple(cell_coord)
        for master_coord, rng_str in getattr(ws, 'array_formulae', {}).items():
            try:
                min_col, min_row, max_col, max_row = range_boundaries(rng_str)
                if min_row <= coord_tuple[0] <= max_row and min_col <= coord_tuple[1] <= max_col:
                    master_val = ws[master_coord].value
                    if hasattr(master_val, 'text') and master_val.text:
                        return "=" + master_val.text.lstrip("=")
                    elif isinstance(master_val, str) and master_val.startswith('='):
                        return master_val
            except Exception:
                continue

        # 2. Formula Recovery (Translates shared formulas downwards if the XML is orphaned)
        error_strings = ("#VALUE!", "#REF!", "#N/A", "#NAME?", "#DIV/0!", "#NUM!", "#NULL!")
        if cell.data_type == 'e' or (isinstance(val, str) and val in error_strings) or not val:
            # Look up to 10 rows above for the master formula
            for r in range(coord_tuple[0] - 1, max(0, coord_tuple[0] - 10), -1):
                above_coord = f"{get_column_letter(coord_tuple[1])}{r}"
                above_cell = ws[above_coord]
                above_val = above_cell.value
                above_formula = None
                
                if isinstance(above_val, str) and above_val.startswith("="):
                    above_formula = above_val
                elif hasattr(above_val, 'text') and above_val.text:
                    above_formula = "=" + above_val.text.lstrip("=")
                    
                if above_formula:
                    try:
                        return Translator(above_formula, origin=above_coord).translate_formula(cell_coord)
                    except Exception:
                        pass
                        
        return val

    def parse_formula(self, formula_text, current_sheet):
        """Attempts to extract references using Tokenizer, falls back to Regex for modern formulas."""
        refs = []
        try:
            tok = Tokenizer(formula_text)
            for t in tok.items:
                if t.type == "OPERAND" and t.subtype == "RANGE":
                    refs.append(self.parse_reference(t.value, current_sheet))
            if refs: return refs
        except Exception:
            pass
            
        # Regex Fallback Engine (Ignores function names, grabs valid sheet/cell coordinates)
        f_clean = re.sub(r'"[^"]*"', '', formula_text)
        pattern = r"((?:'[^']+'|[A-Za-z0-9_. ]+|\[[^\]]+\][^!]+)!)?\$?([A-Za-z]{1,3})\$?(\d+)(?::\$?([A-Za-z]{1,3})\$?(\d+))?"
        
        for match in re.finditer(pattern, f_clean):
            sheet_part, col1, row1, col2, row2 = match.groups()
                
            if sheet_part:
                sheet_part = sheet_part[:-1].strip()
                if sheet_part.startswith("'") and sheet_part.endswith("'"):
                    sheet_part = sheet_part[1:-1]
            else:
                sheet_part = current_sheet
                
            ref_str = f"{col1}{row1}"
            if col2 and row2: ref_str += f":{col2}{row2}"
            refs.append((sheet_part, ref_str))
            
        return refs

    def parse_reference(self, ref_str, current_sheet):
        ref_str = ref_str.replace('$', '').replace('#', '') # Strip absolute/spill anchors
        if "!" in ref_str:
            sheet_part, cell_part = ref_str.rsplit("!", 1)
            sheet_part = sheet_part.strip("'").replace("''", "'")
            if "[" in sheet_part and "]" in sheet_part:
                sheet_part = sheet_part.split("]")[-1]
            return sheet_part, cell_part
        return current_sheet, ref_str

    def expand_range(self, range_str):
        if ":" not in range_str: return [range_str]
        try:
            min_col, min_row, max_col, max_row = range_boundaries(range_str)
            if None in (min_col, max_col, min_row, max_row) or (max_row - min_row + 1) * (max_col - min_col + 1) > 200:
                return [range_str] 
                
            cells = []
            for row in range(min_row, max_row + 1):
                for col in range(min_col, max_col + 1):
                    cells.append(f"{get_column_letter(col)}{row}")
            return cells
        except Exception:
            return [range_str]

    def build_tree(self, sheet_name, cell_coord, depth=0, path=None):
        if path is None: path = set()
        node_id = f"{sheet_name}!{cell_coord}"
        
        node = {
            "sheet": sheet_name, "cell": cell_coord, "name": "", "content": "",
            "note": "", "is_external_tab": False, "children": [], "depth": depth
        }

        if node_id in path:
            node["note"] = "Cycle Detected"
            return node

        if node_id in self.global_visited:
            cached_node = self.global_visited[node_id].copy()
            cached_node["depth"] = depth
            cached_node["children"], cached_node["note"] = [], "[Already Traced]"
            return cached_node

        if sheet_name not in self.sheet_names:
            node["note"], node["is_external_tab"] = "External Workbook / Missing Tab", True
            self.global_visited[node_id] = node.copy()
            return node

        ws = self.wb[sheet_name]
        try:
            min_col, min_row, _, _ = range_boundaries(cell_coord)
        except Exception:
            node["note"] = "Named Range"
            self.global_visited[node_id] = node.copy()
            return node
            
        node["name"] = self.get_cell_name(ws, min_row, min_col)
        
        # Pull formula text using the new robust Recovery Engine
        cell_content = self.get_formula_string(ws, cell_coord)
        node["content"] = str(cell_content) if cell_content is not None else ""

        self.global_visited[node_id] = node.copy()
        path.add(node_id)

        if isinstance(cell_content, str) and cell_content.startswith("="):
            refs = self.parse_formula(cell_content, sheet_name)
            for ref_sheet, ref_range in refs:
                cells = self.expand_range(ref_range)
                for c in cells:
                    child = self.build_tree(ref_sheet, c, depth + 1, path.copy())
                    if ":" in c: child["note"] = "Range too large to trace individually"
                    if ref_sheet != sheet_name:
                        child["note"] = f"External tab ({ref_sheet})"
                        child["is_external_tab"] = True
                    node["children"].append(child)

        return node

    def export_results(self, root, output_path):
        out_wb = openpyxl.Workbook()
        
        # --- TAB 1: Tree View ---
        ws_tree = out_wb.active
        ws_tree.title = "Dependency Tree"
        headers_tree = ["Tree View", "Level", "Is External Tab", "Sheet", "Cell", "Extracted Name", "Formula / Value", "Notes"]
        ws_tree.append(headers_tree)
        for col in range(1, len(headers_tree) + 1):
            ws_tree.cell(row=1, column=col).font = openpyxl.styles.Font(bold=True)
        
        def flatten(n, is_last=True, prefix=""):
            rows = []
            visual = f"[{n['cell']}] {n['name']}".strip() if n["depth"] == 0 else prefix + ("└── " if is_last else "├── ") + f"[{n['cell']}] {n['name']}".strip()
            rows.append([visual, n["depth"], n["is_external_tab"], n["sheet"], n["cell"], n["name"], n["content"], n["note"]])
            
            for i, child in enumerate(n.get("children", [])):
                new_prefix = prefix + ("    " if is_last else "│   ") if n["depth"] > 0 else ""
                rows.extend(flatten(child, i == len(n["children"]) - 1, new_prefix))
            return rows

        for row in flatten(root):
            ws_tree.append(row)
            
        ws_tree.column_dimensions['A'].width = 50
        ws_tree.column_dimensions['F'].width = 25
        ws_tree.column_dimensions['G'].width = 45

        # --- TAB 2: Long Table Variables Row ---
        ws_long = out_wb.create_sheet(title="Long Table Attributes")
        
        ordered_precedents = []
        visited_nodes = set()
        
        # Topological Traversal
        def traverse_pipeline(n):
            node_id = f"{n['sheet']}!{n['cell']}"
            if node_id in visited_nodes: return
            visited_nodes.add(node_id)
            
            # Walk dependent branches first so isolated inputs show up on the far left
            for child in n.get("children", []):
                traverse_pipeline(child)
                
            label = n["name"] if n["name"] else n["cell"]
            display_name = f"[{n['sheet']}!{n['cell']}] {label}".strip()
            ordered_precedents.append(display_name)

        traverse_pipeline(root)
        
        # Ensure column names are unique (to prevent Pandas loading collisions)
        final_columns = []
        used = set()
        for col in ordered_precedents:
            base = col
            counter = 1
            while col in used:
                col = f"{base} ({counter})"
                counter += 1
            used.add(col)
            final_columns.append(col)
            
        ws_long.append(["Topologically sorted execution pipeline for batch inputs:"])
        ws_long.append(final_columns)
        for col in range(1, len(final_columns) + 1):
            ws_long.cell(row=2, column=col).font = openpyxl.styles.Font(bold=True)
            ws_long.column_dimensions[get_column_letter(col)].width = max(25, len(final_columns[col-1]) + 2)

        out_wb.save(output_path)
        print(f"Success! Output generated at: {output_path}")

