def run_variance_swap_hedge(underlyings, valuation_date, expiry_date, vega_notional, swap_type, outputfolder, generate_wex,
                            strip_powers=[0, 1], risk_targets=['Theta', 'Gamma'], alpha=0.00001, strike_range=[0.1, 1.0]):
    '''
    Evaluates and hedges a Variance or Volatility Swap using a portfolio of vanilla options.
    - strip_powers: K-powers to generate initial weights. 0 generates 1/K^2 (Variance), 1 generates 1/K.
    - risk_targets: List of Greeks to map in the Lasso regression, such as ['Theta', 'Gamma'].
    - alpha: L1 Regularization penalty for Lasso regression.
    - strike_range: Tuple indicating the (min, max) strike range filter as a multiple of spot moneyness.
    '''
    os.makedirs(outputfolder, exist_ok=True)
    for thisu in underlyings:
        
        ''' RENDER TRADING PARAMETERS IN TERMINAL '''
        print(f"\nProcessing: {thisu}")
        print("="*50)
        print("HEDGE CONFIGURATION")
        print(f"Swap Type      : {swap_type}")
        print(f"Vega Notional  : {vega_notional}")
        print(f"Strips (K-pwr) : {strip_powers}")
        print(f"Risks Regressed: {risk_targets}")
        print(f"Lasso Alpha    : {alpha}")
        print(f"Moneyness Range: {strike_range}")
        print("="*50)
        
        vanilla, volswap = generate_contexts(ticker=thisu, valuation_date=valuation_date, expiry_date=expiry_date, vega_notional=vega_notional, swap_type=swap_type)
        
        payoffRule = "{Product.{Payoff=x}}"
        percentStrikeRule = "{Product.{PercentStrike=x}}"
        spotRule = "{AssetData.{Price=x}}"
        fixingRule = "{Product.{Schedule[0].{Fixing=x}}}"
        
        spot = volswap.AssetData.Price
        vanilla = pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(vanilla,"{ModelParameters.{PricingMethod=x}}","Analytic"),"{Product.{ExerciseType=x}}","European"), "{ModelParameters.{SkewStickinessRatio=x}}", 1)
        volswap = pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(volswap, "{ModelParameters.{SkewStickinessRatio=x}}", 1), "{ModelParameters.{ConvexityStickinessRatio=x}}", 1)

        div = volswap.AssetData.Dividend
        vd = volswap.ValueDate
        forecast = pymfl.Equities().ContextGetCcyForecastsBase(volswap)[0][0]
        expiry = list(volswap.Product.Schedule)[-1].Date
        fwd = pymfl.Dividend().ForwardPrice(div,forecast,expiry,vd,spot)

        ''' APPLY DYNAMIC MONEYNESS RANGE '''
        kmin = spot * strike_range[0]
        kmax = spot * strike_range[1]
        slides = [spot * (1.0 + 0.01 * x) for x in range(-20, 21)]
        
        npts_put = 7 if thisu == "SPX" else 5
        npts_call = 7 if thisu == "SPX" else 5
        qpoints_put, weights_put = np.polynomial.legendre.leggauss(npts_put)
        qpoints_call, weights_call = np.polynomial.legendre.leggauss(npts_call)

        putStrikes = [0.5 * (fwd + kmin + x * (fwd - kmin)) for x in qpoints_put]
        callStrikes = [1.0 / (0.5 * (1.0 / fwd + 1.0 / kmax + x * (1.0 / fwd - 1.0 / kmax))) for x in qpoints_call]
        callStrikes.sort()
        
        fullStrikes = putStrikes + callStrikes
        
        weights = list(weights_put) + list(weights_call)

        t = (len(volswap.Product.Schedule) - 1) / 252.0
        v = volswap.Product.VarianceUnits
        
        ''' DYNAMIC STRIP POWERS '''
        k_powers = strip_powers
        npower = len(k_powers)
        mink = np.min(fullStrikes)
        maxk = np.max(fullStrikes)
        nslides = len(slides)
        nstrikes = len(fullStrikes)
        
        gammaX = np.zeros((npower, nslides, nstrikes))
        gammaY = np.zeros(nslides)
        thetaX = np.zeros((npower, nslides, nstrikes))
        thetaY = np.zeros(nslides)

        print("Start clustering...")
        st = time.time()
        outputs = pymfl.MflArray.Map(pymfl.MflArray([pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(volswap, spotRule, x), fixingRule, x) for x in slides]), "=Equities.Valuation(,x)", pymfl.BasicTools().RunCluster("MDN"))
        
        vanillaoutputs = pymfl.MflArray.Map(pymfl.MflArray([pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(vanilla, payoffRule, "Put" if k < fwd else "Call"), percentStrikeRule, k / spot), spotRule, sd) for sd in slides for k in fullStrikes]), "=Equities.Valuation(,x)", pymfl.BasicTools().RunCluster("MDN"))
        print('Execution time:', time.time() - st, 'seconds')

        positions = np.zeros((npower, nstrikes))
        volScalar = 10000.0 if translate(volswap.Product.PayoffType) == 0 else 100.0

        for kp in range(npower):
            for i in range(nslides):
                swapVal = outputs[i]
                gammaY[i] = swapVal.Gamma[0].Value(0,0) * slides[i] * slides[i] / 100.0
                thetaY[i] = swapVal.Theta   

                for j in range(nstrikes):
                    k = fullStrikes[j]
                    vanillaVal = vanillaoutputs[i * nstrikes + j]
                    
                    mult = (volScalar * v * (fwd - mink) / (t * k * k) if k < fwd else volScalar * v * (1.0 / fwd - 1.0 / maxk) / t) * np.power(k, k_powers[kp])
                    positions[kp, j] = mult * weights[j]
                    
                    gammaX[kp, i, j] = weights[j] * mult * vanillaVal.Gamma[0].Value(0,0) * slides[i] * slides[i] / 100.0
                    thetaX[kp, i, j] = weights[j] * mult * vanillaVal.Theta

        allextraw = np.zeros([npower, nstrikes])
        
        for kp in range(npower):
            ''' DYNAMIC REGRESSION USING SELECTED RISKS '''
            yvalue_list = []
            xvalue_list = []
            
            gam = np.mean(np.abs(gammaY))
            thet = np.mean(np.abs(thetaY))
            gam = gam if gam > 1e-12 else 1.0
            thet = thet if thet > 1e-12 else 1.0
            
            risks_lower = [r.lower() for r in risk_targets]

            if "theta" in risks_lower:
                yvalue_list.append(thetaY / thet)
                xvalue_list.append(thetaX[kp, :, :] / thet)
            if "gamma" in risks_lower:
                yvalue_list.append(gammaY / gam)
                xvalue_list.append(gammaX[kp, :, :] / gam)
                
            if not yvalue_list:
                raise ValueError("No valid risk targets provided. Use 'Theta', 'Gamma', or both.")

            yvalue = np.concatenate(yvalue_list)
            xvalue = np.concatenate(xvalue_list, axis=0)

            clf = linear_model.Lasso(alpha=alpha, positive=True, fit_intercept=False)
            clf.fit(xvalue, yvalue)
            allextraw[kp,:] = clf.coef_

            extraw = allextraw[kp, :]
            option_types = ["Put" if k < fwd else "Call" for k in fullStrikes]
            final_hedge_quantity = positions[kp, :] * extraw
            
            ''' RENDER HEDGE METRICS TO TERMINAL '''
            score = clf.score(xvalue, yvalue) if np.var(yvalue) > 0 else 0.0
            num_trades = np.sum(extraw > 1e-8)
            print(f"\n---> Metrics for Strip K-power {k_powers[kp]}:")
            print(f"  R^2 Fit Score      : {score:.4f}")
            print(f"  Active Options     : {num_trades} / {nstrikes}")
            
            df_hedge = pd.DataFrame({
                "Underlying": thisu,
                "Strike": fullStrikes,
                "Option_Type": option_types,
                "Theoretical_Weight": positions[kp, :],
                "Lasso_Multiplier": extraw,
                "Final_Trade_Quantity": final_hedge_quantity
            })
            
            csv_path = os.path.join(outputfolder, f"{thisu}_kp{k_powers[kp]}_hedge.csv")
            df_hedge.to_csv(csv_path, index=False)
            print(f"  Saved hedge blotter to: {csv_path}")
            
            if generate_wex:
                wex_path = os.path.join(outputfolder, f"{thisu}_kp{k_powers[kp]}_wex.csv")
                generate_wex_spreadsheet(df_hedge, expiry_date, wex_path)
                print(f"  Saved WeX spreadsheet to: {wex_path}")

