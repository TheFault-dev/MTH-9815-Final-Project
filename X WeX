    if valuation_date == datetime.date.today():
        spot = blp.bdp(bbg_ticker, 'PX_LAST').iloc[0, 0]
        chain = blp.bds(bbg_ticker, 'OPT_CHAIN')
    else:
        is_index = (ticker == "SPX")
        spot_ticker = ticker.replace('-', ' ')
        spot = load_price_from_cmdb(valuation_date, [spot_ticker], 'BLOOMBERG', 'SETTLE', is_index)[0]
        val_date_str = valuation_date.strftime("%Y%m%d")
        chain = blp.bds(bbg_ticker, 'OPT_CHAIN', SINGLE_DATE_OVERRIDE=val_date_str)
        
    exp_str = expiry_date.strftime("%m/%d/%y")
    col_name = chain.columns[0]
    
    chain = chain[chain[col_name].str.contains(exp_str, na=False)]
    strikes = chain[col_name].str.extract(r'[CP](\d+(?:\.\d+)?)').astype(float)[0].dropna().unique()
    strikes = np.sort(strikes)
    
    return strikes[(strikes >= spot * 0.2) & (strikes <= spot * 3.0)]

def calculate_trapezoidal_weights(strikes: np.ndarray, swap_type: str):
    n = len(strikes)
    weights = np.zeros(n)
    
    for i in range(n):
        K = strikes[i]
        if i == 0:
            dK = strikes[1] - strikes[0]
        elif i == n - 1:
            dK = strikes[n-1] - strikes[n-2]
        else:
            dK = (strikes[i+1] - strikes[i-1]) / 2.0
            
        if swap_type == "Volatility":
            weights[i] = dK / K
        else:
            weights[i] = dK / (K ** 2)
            
    return weights

def run_variance_swap_hedge(underlyings, expiry_date, vega_notional, swap_type, outputfolder, generate_wex, valuation_date=None):
    if valuation_date is None:
        valuation_date = datetime.date.today()
        
    os.makedirs(outputfolder, exist_ok=True)
    payoffRule = "{Product.{Payoff=x}}"
    percentStrikeRule = "{Product.{PercentStrike=x}}"
    spotRule = "{AssetData.{Price=x}}"
    fixingRule = "{Product.{Schedule[0].{Fixing=x}}}"

    for thisu in underlyings:
        print(f"\nProcessing: {thisu}")
        vanilla, volswap = generate_contexts(thisu, valuation_date, expiry_date, vega_notional, swap_type)
        
        vanilla = pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(vanilla,"{ModelParameters.{PricingMethod=x}}","Analytic"),"{Product.{ExerciseType=x}}","European"), "{ModelParameters.{SkewStickinessRatio=x}}", 1)
        volswap = pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(volswap, "{ModelParameters.{SkewStickinessRatio=x}}", 1), "{ModelParameters.{ConvexityStickinessRatio=x}}", 1)
        
        spot = volswap.AssetData.Price
        fwd = pymfl.Dividend().ForwardPrice(volswap.AssetData.Dividend, pymfl.Equities().ContextGetCcyForecastsBase(volswap)[0][0], expiry_date, valuation_date, spot)
        
        strikes = get_bbg_strikes(thisu, expiry_date, valuation_date)
        base_weights = calculate_trapezoidal_weights(strikes, swap_type)
        option_types = ["Put" if K < fwd else "Call" for K in strikes]
        
        slides = [spot * (1.0 + 0.01 * x) for x in range(-20, 21)]
        nslides = len(slides)
        nstrikes = len(strikes)
        
        gammaX = np.zeros((nslides, nstrikes))
        gammaY = np.zeros(nslides)
        thetaX = np.zeros((nslides, nstrikes))
        thetaY = np.zeros(nslides)
        
        print(f"DEBUG: Spot extracted dynamically as {spot:.2f} for {valuation_date.strftime('%Y-%m-%d')}")
        print(f"DEBUG: Evaluated {nstrikes} liquid strikes across {nslides} spot slides.")
        
        st = time.time()
        print("Valuing swap across spot slides via pyMFL cluster...")
        outputs = pymfl.MflArray.Map(pymfl.MflArray([pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(volswap, spotRule, x), fixingRule, x) for x in slides]), "=Equities.Valuation(,x)", pymfl.BasicTools().RunCluster("MDN"))
        
        print("Valuing options strip across spot slides via pyMFL cluster...")
        vanillaoutputs = pymfl.MflArray.Map(pymfl.MflArray([pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(pymfl.MflData().SetProperty(vanilla, payoffRule, "Put" if k < fwd else "Call"), percentStrikeRule, k / spot), spotRule, sd) for sd in slides for k in strikes]), "=Equities.Valuation(,x)", pymfl.BasicTools().RunCluster("MDN"))
        print(f"DEBUG: Cluster execution time: {time.time() - st:.2f} seconds")
        
        t = (len(volswap.Product.Schedule) - 1) / 252.0
        v = volswap.Product.VarianceUnits
        volScalar = 100.0 if swap_type == "Volatility" else 10000.0
        theoretical_positions = base_weights * (volScalar * v / t)
        
        for i in range(nslides):
            swapVal = outputs[i]
            gammaY[i] = swapVal.Gamma[0].Value(0,0) * slides[i] * slides[i] / 100.0
            thetaY[i] = swapVal.Theta   

            for j in range(nstrikes):
                vanillaVal = vanillaoutputs[i * nstrikes + j]
                gammaX[i, j] = theoretical_positions[j] * vanillaVal.Gamma[0].Value(0,0) * slides[i] * slides[i] / 100.0
                thetaX[i, j] = theoretical_positions[j] * vanillaVal.Theta
                
        print("DEBUG: Executing Lasso Regression to fit Gamma and Theta...")
        gam = np.mean(np.abs(gammaY))
        thet = np.mean(np.abs(thetaY))
        
        yvalue = np.concatenate((thetaY/thet, gammaY/gam))
        xvalue = np.concatenate((thetaX/thet, gammaX/gam), axis=0)
        
        clf = linear_model.Lasso(alpha=0.00001, positive=True, fit_intercept=False)
        clf.fit(xvalue, yvalue)
        extraw = clf.coef_
        
        print(f"DEBUG: Lasso regression complete. Mean multiplier: {np.mean(extraw):.4f}")
        
        final_trade_quantities = theoretical_positions * extraw
        
        df_hedge = pd.DataFrame({
            "Underlying": thisu,
            "Strike": strikes,
            "Option_Type": option_types,
            "Theoretical_Weight": theoretical_positions,
            "Lasso_Multiplier": extraw, 
            "Final_Trade_Quantity": final_trade_quantities
        })
        
        file_suffix = "1overK" if swap_type == "Volatility" else "1overK2"
        csv_path = os.path.join(outputfolder, f"{thisu}_{file_suffix}_hedge.csv")
        df_hedge.to_csv(csv_path, index=False)
        print(f"Saved hedge blotter to: {csv_path}")
        
        if generate_wex:
            wex_path = os.path.join(outputfolder, f"{thisu}_{file_suffix}_wex.csv")
            generate_wex_spreadsheet(df_hedge, expiry_date, wex_path)
            print(f"Saved WeX spreadsheet to: {wex_path}")

