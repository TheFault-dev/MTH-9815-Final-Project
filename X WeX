        for _, row in df_batch.iterrows():
            v_date = datetime.datetime.strptime(row['valuation_date'], "%Y-%m-%d").date()
            e_date = datetime.datetime.strptime(row['expiry_date'], "%Y-%m-%d").date()
            run_variance_swap_hedge([row['ticker']], v_date, e_date, float(row['vega_notional']), row['swap_type'], args.out_folder, args.s)
