    from xbbg import blp
    import pandas as pd
    
    # Safely format BBG Ticker with the proper yellow key
    bbg_ticker = ticker
    if bbg_ticker == "SPX":
        bbg_ticker = "SPX Index"
    elif not (bbg_ticker.endswith("Index") or bbg_ticker.endswith("Equity")):
        # Convert symbols like NEE-UN to NEE US Equity (Bloomberg mapping)
        bbg_ticker = bbg_ticker.replace("-UN", " US").replace("-", " ") + " Equity"

    try:
        # Check if the requested date is today
        if (isinstance(date, datetime.datetime) and date.date() == datetime.date.today()) or date == datetime.date.today():
            # Use PX_LAST intraday as fallback, as PX_SETTLE might not be published yet
            df = blp.bdp(tickers=bbg_ticker, flds=['PX_SETTLE', 'PX_LAST'])
            if df is None or df.empty: 
                return 0.0
            
            if 'px_settle' in df.columns and pd.notna(df['px_settle'].iloc[0]):
                price = float(df['px_settle'].iloc[0])
            elif 'px_last' in df.columns and pd.notna(df['px_last'].iloc[0]):
                price = float(df['px_last'].iloc[0])
            else:
                return 0.0
        else:
            df = blp.bdh(tickers=bbg_ticker, flds=['PX_SETTLE'], start_date=date, end_date=date)
            if df is None or df.empty: 
                return 0.0
            price = float(df.values[0][0])
            
        if scale:
            unit_df = blp.bdp(tickers=bbg_ticker, flds=['QUOTE_UNITS'])
            quote_unit = unit_df['quote_units'].iloc[0] if (unit_df is not None and not unit_df.empty and 'quote_units' in unit_df.columns) else ''
        else:
            quote_unit = ''
            
        return price * (0.01 if 'USd' in str(quote_unit) else 1.0)
